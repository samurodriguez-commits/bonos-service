# ============================================================
# Variables de entorno de bonos-service
# Copiar a .env (NO commitear el .env real)
# ============================================================

PORT=8004

# Debe ser EL MISMO JWT_SECRET que casino-backend para validar el token.
JWT_SECRET=cambiame-en-produccion

# Postgres (la MISMA BD que casino-backend)
DB_HOST=localhost
DB_PORT=5432
DB_USER=casino
DB_PASSWORD=casino
DB_NAME=casino_db

# CORS: orígenes permitidos separados por coma.
CORS_ORIGIN=http://localhost:4200
